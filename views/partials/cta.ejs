<%
  const ctaHeading = (typeof heading !== 'undefined' && heading) ? heading : 'Ready to build the outbound setup you can own?';
  const ctaText = (typeof text !== 'undefined' && text) ? text : 'Tell us where you are now: starting from zero, leaving a vendor, hiring your first caller, or cleaning up what you already have. We will recommend the simplest next step.';
%>
<section class="section-y">
  <div class="container">
    <div class="relative mx-auto max-w-4xl overflow-hidden rounded-3xl border border-clay-400/20 bg-ink-800 px-6 py-16 text-center md:px-10 md:py-20">
      <div class="pointer-events-none absolute -right-28 -top-28 h-72 w-72 rounded-full bg-clay-500/15 blur-[100px]" aria-hidden="true"></div>
      <div class="pointer-events-none absolute -left-28 -bottom-28 h-72 w-72 rounded-full bg-ink-500/25 blur-[100px]" aria-hidden="true"></div>

      <div class="relative">
        <p class="eyebrow justify-center">Start a project</p>
        <h2 class="mt-4 text-display-sm"><%= ctaHeading %></h2>
        <p class="lead mx-auto mt-5 max-w-2xl"><%= ctaText %></p>
        <div class="mt-9 flex flex-col items-center justify-center gap-3 sm:flex-row">
          <a href="<%= site.cta.primary.href %>" class="btn-primary w-full sm:w-auto">
            <%= site.cta.primary.label %>
            <%- icon('arrow-right', 'arrow h-4 w-4') %>
          </a>
          <a href="mailto:<%= site.contactEmail %>" class="btn-secondary w-full sm:w-auto">
            <%- icon('mail', 'h-4 w-4') %>
            Email us directly
          </a>
        </div>
      </div>
    </div>
  </div>
</section>
