<%
  const orgId = site.siteUrl + '/#organization';
  const siteId = site.siteUrl + '/#website';
  const serviceId = site.siteUrl + '/#service';

  const graph = {
    '@context': 'https://schema.org',
    '@graph': [
      {
        '@type': 'Organization',
        '@id': orgId,
        name: site.brand.name,
        url: site.siteUrl + '/',
        email: site.brand.email,
        slogan: site.brand.slogan,
        description: site.brand.descriptor,
        logo: {
          '@type': 'ImageObject',
          url: site.siteUrl + '/images/icon-512.png',
          width: 512,
          height: 512
        }
      },
      {
        '@type': 'WebSite',
        '@id': siteId,
        url: site.siteUrl + '/',
        name: site.brand.name,
        publisher: { '@id': orgId },
        inLanguage: 'en'
      },
      {
        '@type': 'ProfessionalService',
        '@id': serviceId,
        name: site.brand.name,
        url: site.siteUrl + '/',
        image: site.siteUrl + '/images/veylrio-og.jpg',
        email: site.brand.email,
        description: site.brand.descriptor,
        parentOrganization: { '@id': orgId },
        areaServed: 'Worldwide',
        serviceType: [
          'Outbound sales operation setup',
          'Cold calling system setup',
          'Dialer setup and optimization',
          'CRM and pipeline setup',
          'Caller workflow and sourcing support',
          'Outbound data and reporting setup',
          'Outbound advisory'
        ],
        knowsAbout: [
          'Owned outbound operations',
          'Cold calling systems',
          'Dialer and CRM setup',
          'Caller workflow and data process',
          'Outbound reporting and QA'
        ]
      }
    ]
  };
%>
<script type="application/ld+json" nonce="<%= cspNonce %>"><%- JSON.stringify(graph) %></script>
