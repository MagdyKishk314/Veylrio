<footer class="relative border-t border-cream/10 bg-ink-950 text-paper-200">
  <div class="container relative">
    <div class="grid gap-12 py-16 md:grid-cols-12 md:py-20">
      <!-- Brand -->
      <div class="md:col-span-5">
        <a href="/" class="inline-flex" aria-label="Veylrio — home">
          <img
            src="/logos/veylrio-horizontal-reversed.svg"
            alt="Veylrio"
            width="224"
            height="71"
            class="h-9 w-auto"
          />
        </a>
        <p class="mt-5 max-w-measure text-paper-200/80"><%= site.brand.descriptor %></p>
        <p class="mt-6 font-serif text-lg italic text-clay-400">Less Weight, More Momentum</p>
      </div>

      <!-- Spacer -->
      <div class="hidden md:col-span-1 md:block"></div>

      <!-- Navigate -->
      <div class="md:col-span-3">
        <h2 class="text-xs font-semibold uppercase tracking-eyebrow text-paper-200/60">Navigate</h2>
        <ul class="mt-4 space-y-3">
          <% site.footerNav.forEach(function (item) { %>
            <li>
              <a href="<%= item.href %>" class="text-paper-200/85 transition hover:text-cream">
                <%= item.label %>
              </a>
            </li>
          <% }); %>
        </ul>
      </div>

      <!-- Contact -->
      <div class="md:col-span-3">
        <h2 class="text-xs font-semibold uppercase tracking-eyebrow text-paper-200/60">Get in touch</h2>
        <ul class="mt-4 space-y-3">
          <li>
            <a href="mailto:<%= site.contactEmail %>" class="inline-flex items-center gap-2 text-paper-200/85 transition hover:text-cream">
              <%- icon('mail', 'h-5 w-5 text-clay-400') %>
              <%= site.contactEmail %>
            </a>
          </li>
          <li>
            <a href="<%= site.cta.primary.href %>" class="mt-2 inline-flex items-center gap-2 font-semibold text-cream transition hover:text-clay-400">
              <%= site.cta.primary.label %>
              <%- icon('arrow-right', 'arrow h-4 w-4') %>
            </a>
          </li>
        </ul>
      </div>
    </div>

    <!-- Compliance-conscious language -->
    <p class="max-w-3xl border-t border-cream/10 pt-6 text-xs leading-relaxed text-paper-200/45">
      <%= site.compliance %>
    </p>

    <div class="flex flex-col gap-4 border-t border-cream/10 py-6 text-sm text-paper-200/55 md:flex-row md:items-center md:justify-between">
      <p>&copy; <%= currentYear %> <%= site.brand.legalName %>. All rights reserved.</p>
      <div class="flex flex-wrap items-center gap-x-6 gap-y-2">
        <a href="/privacy-policy" class="transition hover:text-cream">Privacy Policy</a>
        <a href="/terms" class="transition hover:text-cream">Terms</a>
        <span class="text-paper-200/60"><%= site.brand.domain %></span>
      </div>
    </div>
  </div>
</footer>
