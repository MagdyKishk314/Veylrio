<!-- ══ HERO ════════════════════════════════════════════════════════════════ -->
<section class="relative overflow-hidden bg-ink-800 text-cream">
  <div class="pointer-events-none absolute inset-0 pattern-tile opacity-[0.06]" aria-hidden="true"></div>
  <div class="pointer-events-none absolute -left-24 -top-16 h-72 w-72 rounded-full bg-ink-500/40 blur-3xl" aria-hidden="true"></div>
  <div class="container relative">
    <div class="max-w-3xl py-20 md:py-28">
      <p class="eyebrow eyebrow--on-dark">Why Veylrio</p>
      <h1 class="mt-5 text-display text-cream">Operators, not theory. Systems, not slideware.</h1>
      <p class="lead lead--on-dark mt-6 max-w-2xl">
        Plenty of consultants can describe outbound. We have run it. Veylrio builds practical,
        client-owned systems grounded in how calling operations actually work — and we hand them
        back to you clean.
      </p>
    </div>
  </div>
</section>

<!-- ══ STANCE ══════════════════════════════════════════════════════════════ -->
<section class="section-y bg-paper">
  <div class="container">
    <div class="grid gap-12 lg:grid-cols-12 lg:items-center">
      <div class="lg:col-span-6">
        <p class="eyebrow">What we believe</p>
        <h2 class="mt-4 text-display-sm">Outbound works when the operation underneath it works.</h2>
        <div class="mt-6 space-y-4 text-ink-500">
          <p>
            Most outbound teams are not short on effort. They are short on infrastructure — a dialer
            that is configured on purpose, data that stays clean, QA that is measurable, and tracking
            that tells the truth. When those are missing, even great callers lose ground.
          </p>
          <p>
            Veylrio exists to fix that layer. We build the systems and structure that let a team run
            with control instead of chaos, then make sure you can keep running them without us.
          </p>
        </div>
      </div>

      <div class="lg:col-span-6">
        <div class="card-pad bg-white">
          <p class="font-serif text-xl italic text-ink-700">
            “We build the simplest system that gives you control — and then we get out of your way.”
          </p>
          <div class="my-6 rule"></div>
          <ul class="space-y-4">
            <% [
                 'We have sat in the operation, not just the strategy deck.',
                 'We design for the caller, the reviewer and the manager — the people who use it daily.',
                 'We document everything so your team can run and change it.'
               ].forEach(function (line) { %>
              <li class="flex items-start gap-3 text-ink-600">
                <span class="mt-0.5 flex h-6 w-6 shrink-0 items-center justify-center rounded-full bg-clay-600/10 text-clay-700">
                  <%- icon('check', 'h-4 w-4') %>
                </span>
                <span><%= line %></span>
              </li>
            <% }); %>
          </ul>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ══ TRUST POINTS ════════════════════════════════════════════════════════ -->
<section class="section-y bg-paper-100">
  <div class="container">
    <div class="mx-auto max-w-3xl text-center">
      <p class="eyebrow">What makes us different</p>
      <h2 class="mt-4 text-display-sm">Built to be understood, owned and trusted.</h2>
    </div>
    <div class="mt-12 grid gap-5 md:grid-cols-2 lg:grid-cols-3">
      <% site.trustPoints.forEach(function (point) { %>
        <div class="card-pad card-hover h-full">
          <span class="icon-badge"><%- icon('check', 'h-6 w-6') %></span>
          <h3 class="mt-5 text-lg font-semibold text-ink-700"><%= point.title %></h3>
          <p class="mt-2 text-sm leading-relaxed text-ink-500"><%= point.text %></p>
        </div>
      <% }); %>
    </div>
  </div>
</section>

<!-- ══ NO BLACK BOX ════════════════════════════════════════════════════════ -->
<section class="relative overflow-hidden bg-ink-700 text-cream">
  <div class="pointer-events-none absolute inset-0 pattern-tile opacity-[0.05] mask-fade-y" aria-hidden="true"></div>
  <div class="container relative section-y">
    <div class="grid gap-12 lg:grid-cols-12 lg:items-center">
      <div class="lg:col-span-5">
        <p class="eyebrow eyebrow--on-dark">No black boxes</p>
        <h2 class="mt-4 text-display-sm text-cream">You should never be locked out of your own operation.</h2>
        <p class="lead lead--on-dark mt-5">
          We build inside tools you control and document the operation in plain language. If you ever
          stop working with us, nothing breaks and nothing is hidden.
        </p>
      </div>
      <div class="lg:col-span-7">
        <div class="grid gap-px overflow-hidden rounded-2xl border border-cream/10 bg-cream/10 sm:grid-cols-2">
          <% [
               {icon: 'layers', title: 'Operator-built systems', text: 'Designed by people who have run outbound, for people who run it now.'},
               {icon: 'document', title: 'Practical documentation', text: 'Written process your team can follow and new hires can learn from.'},
               {icon: 'sliders', title: 'Client-owned workflows', text: 'Everything lives in tools and accounts that belong to you.'},
               {icon: 'gauge', title: 'Clean handover', text: 'We walk your team through it, then step back — not out of reach, but not in the way.'}
             ].forEach(function (item) { %>
            <div class="bg-ink-700 p-6 md:p-7">
              <span class="icon-badge icon-badge--on-dark"><%- icon(item.icon, 'h-6 w-6') %></span>
              <h3 class="mt-4 text-base font-semibold text-cream"><%= item.title %></h3>
              <p class="mt-2 text-sm leading-relaxed text-paper-200/80"><%= item.text %></p>
            </div>
          <% }); %>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ══ FAQ ═════════════════════════════════════════════════════════════════ -->
<section class="section-y bg-paper">
  <div class="container">
    <div class="grid gap-12 lg:grid-cols-12">
      <div class="lg:col-span-4">
        <p class="eyebrow">Questions</p>
        <h2 class="mt-4 text-display-sm">Straight answers.</h2>
        <p class="mt-5 text-ink-500">
          If your question is not here, email us at
          <a href="mailto:<%= site.contactEmail %>" class="font-semibold text-clay-700 hover:text-clay-800"><%= site.contactEmail %></a>.
        </p>
      </div>
      <div class="lg:col-span-8">
        <div class="divide-y divide-ink-700/10 overflow-hidden rounded-2xl border border-ink-700/10 bg-white">
          <% site.faqs.forEach(function (item) { %>
            <details class="group p-6 md:p-7">
              <summary class="flex cursor-pointer list-none items-center justify-between gap-4">
                <h3 class="text-base font-semibold text-ink-700"><%= item.q %></h3>
                <span class="flex h-7 w-7 shrink-0 items-center justify-center rounded-full bg-ink-700/[0.06] text-ink-700 transition group-open:rotate-45">
                  <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true"><path d="M12 5v14M5 12h14"/></svg>
                </span>
              </summary>
              <p class="mt-3 max-w-prose text-sm leading-relaxed text-ink-500"><%= item.a %></p>
            </details>
          <% }); %>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ══ FINAL CTA ═══════════════════════════════════════════════════════════ -->
<%- include('../partials/cta', { heading: 'See what a calmer outbound operation feels like.', text: 'Tell us how your team runs today. We will review it and reply with a clear, practical view of what to fix first — and how we would build it.' }) %>

<%
  // FAQPage structured data — co-located with the FAQ content above.
  const faqSchema = {
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: site.faqs.map(function (f) {
      return {
        '@type': 'Question',
        name: f.q,
        acceptedAnswer: { '@type': 'Answer', text: f.a }
      };
    })
  };
%>
<script type="application/ld+json" nonce="<%= cspNonce %>"><%- JSON.stringify(faqSchema) %></script>
