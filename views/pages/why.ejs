<!-- ══ HERO ════════════════════════════════════════════════════════════════ -->
<section class="relative overflow-hidden">
  <div class="pointer-events-none absolute -left-40 -top-32 -z-10 h-[30rem] w-[30rem] rounded-full bg-ink-500/25 blur-[120px]" aria-hidden="true"></div>
  <div class="container relative">
    <div class="max-w-3xl py-20 md:py-28">
      <p class="eyebrow">Why Veylrio</p>
      <h1 class="mt-5 text-display">We build the system you keep.</h1>
      <p class="lead mt-6 max-w-2xl">
        Most vendors keep the operation inside a black box. We build it in the open and hand it back —
        because the caller, the data, and the system should belong to your business.
      </p>
    </div>
  </div>
</section>

<!-- ══ BELIEF ══════════════════════════════════════════════════════════════ -->
<section class="section-y band">
  <div class="container">
    <div class="grid gap-12 lg:grid-cols-12 lg:items-center">
      <div class="lg:col-span-6">
        <p class="eyebrow">What we believe</p>
        <h2 class="mt-4 text-display-sm">Paying for outbound is not the same as owning it.</h2>
        <div class="mt-6 space-y-4 text-paper-200/70">
          <p>
            A lot of owners think they are buying outbound. What they are really buying is access to
            someone else’s system — and when they stop paying, they keep almost none of it.
          </p>
          <p>
            We are not anti-vendor. Specialists can help. But the operating truth — the caller, the
            CRM, the data, the recordings, the reporting — should belong to you. That is what we
            build, and that is what we hand over.
          </p>
        </div>
      </div>
      <div class="lg:col-span-6">
        <div class="card-pad">
          <p class="font-serif text-xl italic text-cream">
            “The point is not to avoid help. The point is to own the machine.”
          </p>
          <div class="my-6 rule"></div>
          <ul class="space-y-4">
            <% [
                 'We know outbound from the inside — callers, data, dialers, scripts, follow-up, reporting.',
                 'We build the operation, then teach you how to run it.',
                 'Everything lives in tools and accounts you control.'
               ].forEach(function (line) { %>
              <li class="flex items-start gap-3 text-paper-200/85">
                <span class="mt-0.5 flex h-6 w-6 shrink-0 items-center justify-center rounded-full bg-clay-400/12 text-clay-400">
                  <%- icon('check', 'h-4 w-4') %>
                </span>
                <span><%= line %></span>
              </li>
            <% }); %>
          </ul>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ══ WHY OWNERSHIP MATTERS ═══════════════════════════════════════════════ -->
<section class="section-y">
  <div class="container">
    <div class="mx-auto max-w-3xl text-center">
      <p class="eyebrow">Why ownership matters</p>
      <h2 class="mt-4 text-display-sm">Control compounds over time.</h2>
    </div>
    <div class="mx-auto mt-12 grid max-w-4xl gap-4 sm:grid-cols-2 lg:grid-cols-3">
      <% site.whyOwnership.forEach(function (point) { %>
        <div class="card-pad flex items-start gap-3">
          <span class="mt-0.5 flex h-7 w-7 shrink-0 items-center justify-center rounded-lg bg-clay-400/12 text-clay-400">
            <%- icon('check', 'h-4 w-4') %>
          </span>
          <span class="text-sm font-medium text-cream"><%= point %></span>
        </div>
      <% }); %>
    </div>
  </div>
</section>

<!-- ══ WHAT MAKES VEYLRIO DIFFERENT ════════════════════════════════════════ -->
<section class="section-y band">
  <div class="container">
    <div class="grid gap-12 lg:grid-cols-12">
      <div class="lg:col-span-5">
        <p class="eyebrow">What makes us different</p>
        <h2 class="mt-4 text-display-sm text-cream">Operator-built, and honest about it.</h2>
        <p class="lead mt-5">
          We do not dress up lead-gen or staffing as something else. We build the operating layer and
          stay available — on your terms.
        </p>
      </div>
      <div class="lg:col-span-7">
        <ul class="grid gap-px overflow-hidden rounded-2xl border border-cream/10 bg-cream/10 sm:grid-cols-2">
          <% site.whyDifferent.forEach(function (point) { %>
            <li class="flex items-start gap-3 bg-ink-800 p-5">
              <span class="mt-0.5 flex h-6 w-6 shrink-0 items-center justify-center rounded-full bg-clay-400/12 text-clay-400">
                <%- icon('check', 'h-4 w-4') %>
              </span>
              <span class="text-sm text-paper-200/85"><%= point %></span>
            </li>
          <% }); %>
        </ul>
      </div>
    </div>
  </div>
</section>

<!-- ══ FAQ ═════════════════════════════════════════════════════════════════ -->
<section class="section-y">
  <div class="container">
    <div class="grid gap-12 lg:grid-cols-12">
      <div class="lg:col-span-4">
        <p class="eyebrow">Questions</p>
        <h2 class="mt-4 text-display-sm">Straight answers.</h2>
        <p class="mt-5 text-paper-200/70">
          If your question is not here, email
          <a href="mailto:<%= site.contactEmail %>" class="font-semibold text-clay-400 hover:text-clay-300"><%= site.contactEmail %></a>.
        </p>
      </div>
      <div class="lg:col-span-8">
        <div class="divide-y divide-cream/10 overflow-hidden rounded-2xl border border-cream/10 bg-ink-800">
          <% site.faqs.forEach(function (item) { %>
            <details class="group p-6 md:p-7">
              <summary class="flex cursor-pointer list-none items-center justify-between gap-4">
                <h3 class="text-base font-semibold text-cream"><%= item.q %></h3>
                <span class="flex h-7 w-7 shrink-0 items-center justify-center rounded-full bg-cream/[0.06] text-clay-400 transition group-open:rotate-45">
                  <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true"><path d="M12 5v14M5 12h14"/></svg>
                </span>
              </summary>
              <p class="mt-3 max-w-prose text-sm leading-relaxed text-paper-200/70"><%= item.a %></p>
            </details>
          <% }); %>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ══ FINAL CTA ═══════════════════════════════════════════════════════════ -->
<%- include('../partials/cta', { heading: 'Own the operation, not just the access.', text: 'Tell us where you are now. We will reply with a clear, practical view of what to build first — and what you should own by the end.' }) %>

<%
  const faqSchema = {
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: site.faqs.map(function (f) {
      return { '@type': 'Question', name: f.q, acceptedAnswer: { '@type': 'Answer', text: f.a } };
    })
  };
%>
<script type="application/ld+json" nonce="<%= cspNonce %>"><%- JSON.stringify(faqSchema) %></script>
