<%
  function val(name) { return (values && values[name]) ? values[name] : ''; }
  function err(name) { return (errors && errors[name]) ? errors[name] : ''; }
  function inputClass(name) { return err(name) ? 'input input-invalid' : 'input'; }
  function selectClass(name) { return err(name) ? 'select input-invalid' : 'select'; }
  function textareaClass(name) { return err(name) ? 'textarea input-invalid' : 'textarea'; }
  const hasErrors = errors && Object.keys(errors).length > 0;
%>

<!-- ══ HEADER ══════════════════════════════════════════════════════════════ -->
<section class="relative overflow-hidden">
  <div class="pointer-events-none absolute -right-40 -top-32 -z-10 h-[28rem] w-[28rem] rounded-full bg-clay-500/10 blur-[120px]" aria-hidden="true"></div>
  <div class="container relative">
    <div class="max-w-3xl py-16 md:py-20">
      <p class="eyebrow">Start a Project</p>
      <h1 class="mt-5 text-display">Let’s build the outbound setup you can own.</h1>
      <p class="lead mt-6 max-w-2xl">
        Tell us where you are now: starting from zero, leaving a vendor, hiring a caller, or cleaning
        up what you already have. We will review it and recommend the simplest practical next step.
      </p>
    </div>
  </div>
</section>

<!-- ══ FORM ════════════════════════════════════════════════════════════════ -->
<section class="section-y">
  <div class="container">
    <div class="grid gap-10 lg:grid-cols-12">
      <!-- Form -->
      <div class="lg:col-span-8">
        <% if (hasErrors) { %>
          <div class="mb-8 rounded-2xl border border-clay-400/30 bg-clay-400/[0.08] p-5" role="alert">
            <p class="font-semibold text-clay-300">Please check the highlighted fields.</p>
            <p class="mt-1 text-sm text-paper-200/60">A few details need fixing before we can send this through.</p>
          </div>
        <% } %>

        <form method="POST" action="/start-a-project" novalidate class="space-y-10">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
          <div class="hp-field" aria-hidden="true">
            <label for="_hp_company_url">Company URL (leave this empty)</label>
            <input type="text" id="_hp_company_url" name="_hp_company_url" tabindex="-1" autocomplete="off" />
          </div>

          <!-- About you -->
          <fieldset class="space-y-6">
            <legend class="text-xs font-semibold uppercase tracking-eyebrow text-clay-400">About you</legend>
            <div class="grid gap-6 sm:grid-cols-2">
              <div>
                <label for="name" class="field-label">Name <span class="text-clay-400">*</span></label>
                <input type="text" id="name" name="name" value="<%= val('name') %>" autocomplete="name" required maxlength="100"
                  class="<%= inputClass('name') %>" <%= err('name') ? 'aria-invalid="true" aria-describedby="name-error"' : '' %> />
                <% if (err('name')) { %><p id="name-error" class="field-error"><%= err('name') %></p><% } %>
              </div>
              <div>
                <label for="company" class="field-label">Company <span class="text-clay-400">*</span></label>
                <input type="text" id="company" name="company" value="<%= val('company') %>" autocomplete="organization" required maxlength="120"
                  class="<%= inputClass('company') %>" <%= err('company') ? 'aria-invalid="true" aria-describedby="company-error"' : '' %> />
                <% if (err('company')) { %><p id="company-error" class="field-error"><%= err('company') %></p><% } %>
              </div>
              <div>
                <label for="email" class="field-label">Email <span class="text-clay-400">*</span></label>
                <input type="email" id="email" name="email" value="<%= val('email') %>" autocomplete="email" required maxlength="160"
                  class="<%= inputClass('email') %>" <%= err('email') ? 'aria-invalid="true" aria-describedby="email-error"' : '' %> />
                <% if (err('email')) { %><p id="email-error" class="field-error"><%= err('email') %></p><% } %>
              </div>
              <div>
                <label for="phone" class="field-label">Phone / WhatsApp <span class="text-clay-400">*</span></label>
                <input type="tel" id="phone" name="phone" value="<%= val('phone') %>" autocomplete="tel" required maxlength="40"
                  class="<%= inputClass('phone') %>" <%= err('phone') ? 'aria-invalid="true" aria-describedby="phone-error"' : '' %> />
                <% if (err('phone')) { %><p id="phone-error" class="field-error"><%= err('phone') %></p><% } %>
              </div>
            </div>
          </fieldset>

          <div class="rule"></div>

          <!-- Your situation -->
          <fieldset class="space-y-6">
            <legend class="text-xs font-semibold uppercase tracking-eyebrow text-clay-400">Your situation</legend>

            <div>
              <span class="field-label">Where are you with outbound? <span class="text-clay-400">*</span></span>
              <div class="grid gap-3 sm:grid-cols-2">
                <% options.outboundStatus.forEach(function (opt) { %>
                  <label class="flex cursor-pointer items-center gap-3 rounded-xl border border-cream/15 bg-ink-950/40 px-4 py-3 transition hover:border-cream/30 has-[:checked]:border-clay-400 has-[:checked]:bg-clay-400/10">
                    <input type="radio" name="outboundStatus" value="<%= opt %>" <%= val('outboundStatus') === opt ? 'checked' : '' %> class="peer sr-only" />
                    <span class="flex h-4 w-4 shrink-0 items-center justify-center rounded-full border border-cream/30 peer-checked:border-clay-400">
                      <span class="h-2 w-2 rounded-full bg-clay-400 opacity-0 peer-checked:opacity-100"></span>
                    </span>
                    <span class="text-sm text-paper-200/80 peer-checked:text-cream"><%= opt %></span>
                  </label>
                <% }); %>
              </div>
              <% if (err('outboundStatus')) { %><p class="field-error"><%= err('outboundStatus') %></p><% } %>
            </div>

            <div class="grid gap-6 sm:grid-cols-2">
              <div>
                <label for="industry" class="field-label">Industry <span class="text-clay-400">*</span></label>
                <select id="industry" name="industry" required class="<%= selectClass('industry') %>"
                  <%= err('industry') ? 'aria-invalid="true" aria-describedby="industry-error"' : '' %>>
                  <option value="" <%= val('industry') ? '' : 'selected' %> disabled>Select an industry…</option>
                  <% options.industries.forEach(function (opt) { %>
                    <option value="<%= opt %>" <%= val('industry') === opt ? 'selected' : '' %>><%= opt %></option>
                  <% }); %>
                </select>
                <% if (err('industry')) { %><p id="industry-error" class="field-error"><%= err('industry') %></p><% } %>
              </div>
              <div>
                <label for="stack" class="field-label">Current dialer or CRM <span class="text-paper-200/45 font-normal">(optional)</span></label>
                <input type="text" id="stack" name="stack" value="<%= val('stack') %>" maxlength="160" placeholder="e.g. a power dialer + a CRM, or “not sure”"
                  class="<%= inputClass('stack') %>" <%= err('stack') ? 'aria-invalid="true" aria-describedby="stack-error"' : '' %> />
                <% if (err('stack')) { %><p id="stack-error" class="field-error"><%= err('stack') %></p><% } %>
              </div>
            </div>

            <div>
              <label for="needs" class="field-label">What do you want to build or fix? <span class="text-clay-400">*</span></label>
              <textarea id="needs" name="needs" required maxlength="2000" data-counter="needs-count" rows="4"
                placeholder="Building from zero, leaving a vendor, hiring a caller, cleaner reporting — whatever is on your mind."
                class="<%= textareaClass('needs') %>" <%= err('needs') ? 'aria-invalid="true" aria-describedby="needs-error needs-count"' : 'aria-describedby="needs-count"' %>><%= val('needs') %></textarea>
              <div class="flex items-center justify-between">
                <% if (err('needs')) { %><p id="needs-error" class="field-error"><%= err('needs') %></p><% } else { %><span></span><% } %>
                <span id="needs-count" class="field-hint"></span>
              </div>
            </div>
          </fieldset>

          <div class="rule"></div>

          <!-- Logistics -->
          <fieldset class="space-y-6">
            <legend class="text-xs font-semibold uppercase tracking-eyebrow text-clay-400">Logistics</legend>
            <div class="grid gap-6 sm:grid-cols-3">
              <div>
                <label for="timeline" class="field-label">Timeline <span class="text-clay-400">*</span></label>
                <select id="timeline" name="timeline" required class="<%= selectClass('timeline') %>"
                  <%= err('timeline') ? 'aria-invalid="true" aria-describedby="timeline-error"' : '' %>>
                  <option value="" <%= val('timeline') ? '' : 'selected' %> disabled>Choose…</option>
                  <% options.timelines.forEach(function (opt) { %>
                    <option value="<%= opt %>" <%= val('timeline') === opt ? 'selected' : '' %>><%= opt %></option>
                  <% }); %>
                </select>
                <% if (err('timeline')) { %><p id="timeline-error" class="field-error"><%= err('timeline') %></p><% } %>
              </div>
              <div>
                <label for="contactMethod" class="field-label">Preferred contact <span class="text-clay-400">*</span></label>
                <select id="contactMethod" name="contactMethod" required class="<%= selectClass('contactMethod') %>"
                  <%= err('contactMethod') ? 'aria-invalid="true" aria-describedby="contactMethod-error"' : '' %>>
                  <option value="" <%= val('contactMethod') ? '' : 'selected' %> disabled>Choose…</option>
                  <% options.contactMethods.forEach(function (opt) { %>
                    <option value="<%= opt %>" <%= val('contactMethod') === opt ? 'selected' : '' %>><%= opt %></option>
                  <% }); %>
                </select>
                <% if (err('contactMethod')) { %><p id="contactMethod-error" class="field-error"><%= err('contactMethod') %></p><% } %>
              </div>
              <div>
                <label for="budget" class="field-label">Budget <span class="text-paper-200/45 font-normal">(optional)</span></label>
                <select id="budget" name="budget" class="<%= selectClass('budget') %>"
                  <%= err('budget') ? 'aria-invalid="true" aria-describedby="budget-error"' : '' %>>
                  <option value="" <%= val('budget') ? '' : 'selected' %>>Prefer not to say</option>
                  <% options.budgetRanges.forEach(function (opt) { %>
                    <option value="<%= opt %>" <%= val('budget') === opt ? 'selected' : '' %>><%= opt %></option>
                  <% }); %>
                </select>
                <% if (err('budget')) { %><p id="budget-error" class="field-error"><%= err('budget') %></p><% } %>
              </div>
            </div>
          </fieldset>

          <div class="flex flex-col gap-4 pt-2 sm:flex-row sm:items-center sm:justify-between">
            <button type="submit" class="btn-primary w-full sm:w-auto">
              <%= site.cta.primary.label %>
              <%- icon('arrow-right', 'arrow h-4 w-4') %>
            </button>
            <p class="text-xs text-paper-200/45">
              By submitting, you agree to our <a href="/privacy-policy" class="underline hover:text-paper-200">Privacy Policy</a>.
            </p>
          </div>
        </form>
      </div>

      <!-- Sidebar -->
      <aside class="lg:col-span-4">
        <div class="lg:sticky lg:top-28 space-y-5">
          <div class="card-pad">
            <h2 class="text-base font-semibold text-cream">What happens next</h2>
            <ol class="mt-4 space-y-4">
              <% [
                   {n: '1', t: 'We review your situation', d: 'A person reads your details — not a bot, not a generic auto-reply.'},
                   {n: '2', t: 'We reply with the next step', d: 'Through your preferred contact method, with a clear, practical recommendation.'},
                   {n: '3', t: 'We scope what you should own', d: 'If it is a fit, we map what to build and what you keep by the end.'}
                 ].forEach(function (s) { %>
                <li class="flex items-start gap-3">
                  <span class="flex h-7 w-7 shrink-0 items-center justify-center rounded-full bg-clay-400/12 font-display text-sm font-semibold text-clay-400"><%= s.n %></span>
                  <div>
                    <p class="text-sm font-semibold text-cream"><%= s.t %></p>
                    <p class="mt-1 text-sm text-paper-200/60"><%= s.d %></p>
                  </div>
                </li>
              <% }); %>
            </ol>
          </div>
          <div class="card-pad">
            <p class="text-sm text-paper-200/70">
              Prefer email? Reach us at
              <a href="mailto:<%= site.contactEmail %>" class="font-semibold text-clay-400 hover:text-clay-300"><%= site.contactEmail %></a>.
              Feel free to attach screenshots, sheets, or notes.
            </p>
          </div>
        </div>
      </aside>
    </div>
  </div>
</section>
