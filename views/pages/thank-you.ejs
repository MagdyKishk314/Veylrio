<section class="relative overflow-hidden bg-ink-800 text-cream">
  <div class="pointer-events-none absolute inset-0 pattern-tile opacity-[0.06]" aria-hidden="true"></div>
  <div class="pointer-events-none absolute -right-24 -top-20 h-72 w-72 rounded-full bg-clay-600/15 blur-3xl" aria-hidden="true"></div>

  <div class="container relative">
    <div class="mx-auto max-w-2xl py-24 text-center md:py-32">
      <span class="mx-auto flex h-16 w-16 items-center justify-center rounded-2xl bg-cream/10 text-clay-400">
        <%- icon('check', 'h-8 w-8') %>
      </span>
      <p class="eyebrow eyebrow--on-dark mt-8 justify-center">Received</p>
      <h1 class="mt-4 text-display text-cream">Thank you for reaching out.</h1>
      <p class="lead lead--on-dark mx-auto mt-6 max-w-xl">
        We have your details. A real person will review them and reply through your preferred contact
        method with a clear, practical next step.
      </p>

      <div class="mx-auto mt-10 max-w-lg rounded-2xl border border-cream/10 bg-ink-700/60 p-6 text-left backdrop-blur-sm">
        <p class="text-sm text-paper-200/85">
          If anything would help us understand your operation faster — screenshots, a sample sheet,
          dialer or CRM exports, or a few notes on your current workflow — send them to
          <a href="mailto:<%= contactEmail %>" class="font-semibold text-clay-400 hover:text-clay-300"><%= contactEmail %></a>.
          No pressure, only if it is relevant.
        </p>
      </div>

      <div class="mt-10 flex flex-col items-center justify-center gap-3 sm:flex-row">
        <a href="/" class="btn-on-dark">Back to home</a>
        <a href="/solutions" class="btn-outline-on-dark">Explore Solutions</a>
      </div>
    </div>
  </div>
</section>
