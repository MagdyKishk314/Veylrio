<section class="relative overflow-hidden">
  <div class="pointer-events-none absolute -right-32 -top-24 -z-10 h-[28rem] w-[28rem] rounded-full bg-clay-500/12 blur-[120px]" aria-hidden="true"></div>

  <div class="container relative">
    <div class="mx-auto max-w-2xl py-24 text-center md:py-32">
      <span class="mx-auto flex h-16 w-16 items-center justify-center rounded-2xl bg-clay-400/12 text-clay-400">
        <%- icon('check', 'h-8 w-8') %>
      </span>
      <p class="eyebrow mt-8 justify-center">Received</p>
      <h1 class="mt-4 text-display">Thank you for reaching out.</h1>
      <p class="lead mx-auto mt-6 max-w-xl">
        We have your details. A real person will review them and reply through your preferred contact
        method with a clear, practical next step.
      </p>

      <div class="mx-auto mt-10 max-w-lg rounded-2xl border border-cream/10 bg-ink-800 p-6 text-left">
        <p class="text-xs font-semibold uppercase tracking-eyebrow text-clay-400">What happens next</p>
        <ol class="mt-4 space-y-3">
          <% [
               'We review your situation.',
               'We reply with the simplest practical next step.',
               'If it is a fit, we scope the setup you should own.'
             ].forEach(function (step, i) { %>
            <li class="flex items-start gap-3">
              <span class="flex h-6 w-6 shrink-0 items-center justify-center rounded-full bg-clay-400/12 font-display text-xs font-semibold text-clay-400"><%= i + 1 %></span>
              <span class="text-sm text-paper-200/85"><%= step %></span>
            </li>
          <% }); %>
        </ol>
        <p class="mt-5 border-t border-cream/10 pt-4 text-sm text-paper-200/60">
          Anything that helps us understand faster — screenshots, a sample sheet, or notes — can go to
          <a href="mailto:<%= contactEmail %>" class="font-semibold text-clay-400 hover:text-clay-300"><%= contactEmail %></a>.
        </p>
      </div>

      <div class="mt-10 flex flex-col items-center justify-center gap-3 sm:flex-row">
        <a href="/" class="btn-primary">Back to home</a>
        <a href="/solutions" class="btn-secondary">Explore Solutions</a>
      </div>
    </div>
  </div>
</section>
