<!-- ══ HERO ════════════════════════════════════════════════════════════════ -->
<section class="hero-screen relative isolate flex items-center overflow-hidden">
  <!-- Brand "signal-fan" pattern on paper (dialed back so the headline pops) -->
  <div class="absolute inset-0 -z-10 bg-paper" aria-hidden="true"></div>
  <div class="hero-pattern absolute inset-0 -z-10 opacity-50" aria-hidden="true"></div>
  <div class="pointer-events-none absolute inset-x-0 bottom-0 -z-10 h-32 bg-gradient-to-b from-transparent to-paper" aria-hidden="true"></div>

  <div class="container relative w-full">
    <div class="grid items-center gap-10 py-14 lg:grid-cols-12 lg:gap-8">
      <!-- Copy -->
      <div class="lg:col-span-7">
        <img src="/logos/veylrio-mark-fullcolor.svg" alt="Veylrio" width="128" height="128" class="mb-7 h-14 w-14 lg:hidden" />

        <p class="eyebrow">Build &amp; own your outbound</p>

        <h1 class="mt-6">
          <span class="block font-display font-bold tracking-tight text-ink-700 leading-[1.04] text-[clamp(2.2rem,1rem+4.4vw,4.25rem)]">Build your own outbound operation.</span>
          <span class="mt-1 block font-serif italic font-medium text-clay-600 leading-[1.08] text-[clamp(2.2rem,1rem+4.4vw,4.25rem)]">Stop renting one.</span>
        </h1>

        <p class="lead mt-7 max-w-xl text-ink-600">
          Veylrio sets up the dialer, CRM, caller workflow, data process, reporting, and operating
          structure — so your business runs outbound with visibility and control.
        </p>

        <p class="mt-4 max-w-xl text-ink-500">
          Leaving a vendor, replacing a network, hiring your first caller, or starting cold calling
          for the first time — we build the system so you can run it.
        </p>

        <div class="mt-9 flex flex-col gap-3 sm:flex-row">
          <a href="<%= site.cta.primary.href %>" class="btn-primary">
            <%= site.cta.primary.label %>
            <%- icon('arrow-right', 'arrow h-4 w-4') %>
          </a>
          <a href="<%= site.cta.secondary.href %>" class="btn-secondary">
            <%= site.cta.secondary.label %>
          </a>
        </div>

        <p class="mt-10 text-sm font-medium text-ink-500">
          For real estate investors, home services, realtors, agencies, and owners leaving vendors.
        </p>
      </div>

      <!-- Brand mark medallion (desktop) -->
      <div class="hidden lg:col-span-5 lg:flex lg:items-center lg:justify-center">
        <div class="relative flex aspect-square w-full max-w-sm items-center justify-center">
          <span class="absolute h-[28rem] w-[28rem] rounded-full border border-ink-700/5" aria-hidden="true"></span>
          <span class="absolute h-[21rem] w-[21rem] rounded-full border border-ink-700/10" aria-hidden="true"></span>
          <span class="absolute h-60 w-60 rounded-full bg-paper-100/70 blur-2xl" aria-hidden="true"></span>
          <img src="/logos/veylrio-mark-fullcolor.svg" alt="" aria-hidden="true" width="128" height="128" class="relative h-44 w-44 xl:h-52 xl:w-52" />
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ══ TESTIMONIALS (auto-hides when site.testimonials is empty) ═══════════ -->
<%- include('../partials/testimonials') %>

<!-- ══ PROBLEM ═════════════════════════════════════════════════════════════ -->
<section class="section-y bg-paper">
  <div class="container">
    <div class="mx-auto max-w-3xl text-center">
      <p class="eyebrow">The black-box problem</p>
      <h2 class="mt-4 text-display-sm">You should not need to rent a black box to run outbound.</h2>
      <p class="lead mt-5">
        Many businesses pay a vendor, network, or agency every month and still do not control the
        caller, the data, the CRM, the recordings, or the reporting. That is dependency — and it
        makes it hard to tell why anything is or is not working.
      </p>
    </div>

    <ul class="mx-auto mt-12 grid max-w-5xl gap-4 sm:grid-cols-2">
      <% site.problems.forEach(function (problem) { %>
        <li class="card-pad flex items-start gap-4">
          <span class="mt-0.5 flex h-7 w-7 shrink-0 items-center justify-center rounded-full bg-clay-600/10 text-clay-700">
            <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true"><path d="M6 6l12 12M18 6 6 18"/></svg>
          </span>
          <span class="text-ink-600"><%= problem %></span>
        </li>
      <% }); %>
    </ul>
  </div>
</section>

<!-- ══ WHAT YOU OWN ════════════════════════════════════════════════════════ -->
<section class="relative overflow-hidden bg-ink-700 text-cream">
  <div class="pointer-events-none absolute inset-0 pattern-tile opacity-[0.05] mask-fade-y" aria-hidden="true"></div>
  <div class="container relative section-y">
    <div class="grid gap-12 lg:grid-cols-12">
      <div class="lg:col-span-5">
        <p class="eyebrow eyebrow--on-dark">What you own</p>
        <h2 class="mt-4 text-display-sm text-cream">By the end, the operation belongs to you.</h2>
        <p class="lead lead--on-dark mt-5">
          Owning your outbound does not mean doing everything yourself. It means the core operating
          asset lives in tools and accounts you control — and stays with you even if you ever stop
          working with us.
        </p>
        <p class="mt-6 font-serif text-xl italic text-clay-400">Less Weight, More Momentum</p>
      </div>

      <div class="lg:col-span-7">
        <ul class="grid gap-px overflow-hidden rounded-2xl border border-cream/10 bg-cream/10 sm:grid-cols-2 lg:grid-cols-3">
          <% site.ownItems.forEach(function (item) { %>
            <li class="flex items-center gap-3 bg-ink-700 p-5">
              <span class="flex h-7 w-7 shrink-0 items-center justify-center rounded-full bg-cream/10 text-clay-400">
                <%- icon('check', 'h-4 w-4') %>
              </span>
              <span class="text-sm font-medium text-cream"><%= item %></span>
            </li>
          <% }); %>
        </ul>
      </div>
    </div>
  </div>
</section>

<!-- ══ COST ADVANTAGE ══════════════════════════════════════════════════════ -->
<section class="section-y bg-paper">
  <div class="container">
    <div class="grid gap-10 lg:grid-cols-12 lg:items-center">
      <div class="lg:col-span-6">
        <p class="eyebrow">The cost angle</p>
        <h2 class="mt-4 text-display-sm">Cheaper because the waste is removed — not the quality.</h2>
        <p class="mt-6 text-ink-500"><%= site.costAdvantage.body %></p>
      </div>
      <div class="lg:col-span-6">
        <div class="rounded-2xl border border-clay-600/25 bg-clay-600/[0.06] p-7 md:p-9">
          <span class="icon-badge icon-badge--clay"><%- icon('gauge', 'h-6 w-6') %></span>
          <p class="mt-5 font-display text-xl font-semibold leading-snug text-ink-700">
            <%= site.costAdvantage.callout %>
          </p>
          <p class="mt-4 text-sm text-ink-500">
            More of your budget reaches the caller, the data, and the system — not vendor margin and
            overhead.
          </p>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ══ WHAT WE BUILD ═══════════════════════════════════════════════════════ -->
<section class="section-y bg-paper-100">
  <div class="container">
    <div class="mx-auto max-w-3xl text-center">
      <p class="eyebrow">What we build</p>
      <h2 class="mt-4 text-display-sm">The working parts of an outbound operation you own.</h2>
      <p class="lead mt-5">
        We build the whole launch system — not isolated pieces — and design the process first, then
        the tools around it.
      </p>
    </div>

    <div class="mt-12 grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
      <% site.builds.forEach(function (b) { %>
        <div class="card-pad card-hover h-full">
          <span class="icon-badge"><%- icon(b.icon, 'h-6 w-6') %></span>
          <h3 class="mt-5 text-base font-semibold text-ink-700"><%= b.title %></h3>
          <p class="mt-2 text-sm leading-relaxed text-ink-500"><%= b.text %></p>
        </div>
      <% }); %>
    </div>
  </div>
</section>

<!-- ══ WHO IT IS FOR ═══════════════════════════════════════════════════════ -->
<section class="section-y bg-paper">
  <div class="container">
    <div class="mx-auto max-w-3xl text-center">
      <p class="eyebrow">Who it is for</p>
      <h2 class="mt-4 text-display-sm">Owners who want outbound they control.</h2>
      <p class="lead mt-5">
        If you want direct conversations — and you are tired of paying for outbound you cannot see
        into — you are who we build for.
      </p>
    </div>
    <div class="mx-auto mt-10 flex max-w-4xl flex-wrap justify-center gap-3">
      <% site.audiences.forEach(function (audience) { %>
        <span class="chip"><%= audience %></span>
      <% }); %>
    </div>
  </div>
</section>

<!-- ══ HOW IT WORKS ════════════════════════════════════════════════════════ -->
<section class="relative overflow-hidden bg-ink-700 text-cream">
  <div class="pointer-events-none absolute inset-0 pattern-tile opacity-[0.05] mask-fade-y" aria-hidden="true"></div>
  <div class="container relative section-y">
    <div class="mx-auto max-w-3xl text-center">
      <p class="eyebrow eyebrow--on-dark justify-center">How it works</p>
      <h2 class="mt-4 text-display-sm text-cream">A clear path from rented to owned.</h2>
      <p class="lead lead--on-dark mx-auto mt-5 max-w-2xl">
        No black-box setup. Every step is visible, practical, and handed back to you.
      </p>
    </div>

    <ol class="mt-14 grid gap-px overflow-hidden rounded-2xl border border-cream/10 bg-cream/10 sm:grid-cols-2 lg:grid-cols-3">
      <% site.process.forEach(function (step) { %>
        <li class="bg-ink-700 p-6 md:p-7">
          <span class="font-display text-3xl font-semibold text-clay-400/40"><%= step.number %></span>
          <h3 class="mt-3 text-lg font-semibold text-cream"><%= step.title %></h3>
          <p class="mt-2 text-sm leading-relaxed text-paper-200/80"><%= step.text %></p>
        </li>
      <% }); %>
    </ol>
  </div>
</section>

<!-- ══ OWN VS VENDOR ═══════════════════════════════════════════════════════ -->
<section class="section-y bg-paper">
  <div class="container">
    <div class="mx-auto max-w-3xl text-center">
      <p class="eyebrow">Own vs rent</p>
      <h2 class="mt-4 text-display-sm">Same channel. A very different position.</h2>
    </div>

    <div class="mx-auto mt-12 max-w-4xl overflow-hidden rounded-2xl border border-ink-700/10 bg-white shadow-card">
      <!-- header -->
      <div class="grid grid-cols-1 sm:grid-cols-2">
        <div class="border-b border-ink-700/10 px-6 py-4 sm:border-r">
          <p class="text-xs font-semibold uppercase tracking-eyebrow text-ink-400">Renting · vendor or network</p>
        </div>
        <div class="border-b border-ink-700/10 bg-ink-700/[0.03] px-6 py-4">
          <p class="text-xs font-semibold uppercase tracking-eyebrow text-clay-700">Owning · with Veylrio</p>
        </div>
      </div>
      <!-- rows -->
      <% site.ownVsVendor.forEach(function (row, i) { %>
        <div class="grid grid-cols-1 sm:grid-cols-2 <%= i < site.ownVsVendor.length - 1 ? 'border-b border-ink-700/10' : '' %>">
          <div class="flex items-start gap-3 px-6 py-5 sm:border-r sm:border-ink-700/10">
            <svg class="mt-0.5 h-4 w-4 shrink-0 text-ink-300" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true"><path d="M6 6l12 12M18 6 6 18"/></svg>
            <span class="text-sm text-ink-500"><%= row.vendor %></span>
          </div>
          <div class="flex items-start gap-3 bg-ink-700/[0.03] px-6 py-5">
            <span class="mt-0.5 text-clay-700"><%- icon('check', 'h-4 w-4') %></span>
            <span class="text-sm font-medium text-ink-700"><%= row.owned %></span>
          </div>
        </div>
      <% }); %>
    </div>
  </div>
</section>

<!-- ══ OPTIONAL SUPPORT ════════════════════════════════════════════════════ -->
<section class="section-y bg-paper-100">
  <div class="container">
    <div class="grid gap-10 lg:grid-cols-12 lg:items-end">
      <div class="lg:col-span-7">
        <p class="eyebrow">Optional support</p>
        <h2 class="mt-4 text-display-sm">Help when you want it — never a dependency.</h2>
      </div>
      <div class="lg:col-span-5">
        <p class="text-ink-500">
          The core operation is yours. When it is useful, we stay available for data, dialer, caller,
          QA, or advisory support — on your terms.
        </p>
      </div>
    </div>

    <div class="mt-12 grid gap-5 md:grid-cols-2 lg:grid-cols-3">
      <% site.offers.forEach(function (offer) { %>
        <a href="/solutions#<%= offer.id %>" class="card-pad card-hover group flex h-full flex-col">
          <span class="icon-badge icon-badge--clay"><%- icon(offer.icon, 'h-6 w-6') %></span>
          <h3 class="mt-5 text-lg font-semibold text-ink-700"><%= offer.title %></h3>
          <p class="mt-2 flex-1 text-sm leading-relaxed text-ink-500"><%= offer.positioning %></p>
          <span class="mt-5 inline-flex items-center gap-1.5 text-sm font-semibold text-clay-700">
            See what’s included
            <%- icon('arrow-right', 'arrow h-4 w-4') %>
          </span>
        </a>
      <% }); %>

      <div class="card-pad flex h-full flex-col justify-between bg-ink-700 text-cream">
        <div>
          <h3 class="text-lg font-semibold text-cream">Not sure where you fit?</h3>
          <p class="mt-2 text-sm leading-relaxed text-paper-200/80">
            Tell us how you get customers today. We will point to the simplest way to build the setup
            you should own.
          </p>
        </div>
        <a href="<%= site.cta.primary.href %>" class="btn-on-dark mt-6 w-full">
          <%= site.cta.primary.label %>
          <%- icon('arrow-right', 'arrow h-4 w-4') %>
        </a>
      </div>
    </div>
  </div>
</section>

<!-- ══ TRUST PRINCIPLES ════════════════════════════════════════════════════ -->
<section class="section-y bg-paper">
  <div class="container">
    <div class="mx-auto max-w-3xl text-center">
      <p class="eyebrow">What we will and won’t do</p>
      <h2 class="mt-4 text-display-sm">Straight, operator-built, no black boxes.</h2>
    </div>
    <ul class="mx-auto mt-12 grid max-w-4xl gap-4 sm:grid-cols-2">
      <% site.trustPrinciples.forEach(function (p) { %>
        <li class="card-pad flex items-start gap-4 <%= p.kind === 'yes' ? 'sm:col-span-2 bg-ink-700 text-cream border-ink-700' : '' %>">
          <% if (p.kind === 'yes') { %>
            <span class="mt-0.5 flex h-7 w-7 shrink-0 items-center justify-center rounded-full bg-cream/10 text-clay-400"><%- icon('check', 'h-4 w-4') %></span>
            <span class="font-medium text-cream"><%= p.text %></span>
          <% } else { %>
            <span class="mt-0.5 flex h-7 w-7 shrink-0 items-center justify-center rounded-full bg-clay-600/10 text-clay-700">
              <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true"><path d="M6 6l12 12M18 6 6 18"/></svg>
            </span>
            <span class="text-ink-600"><%= p.text %></span>
          <% } %>
        </li>
      <% }); %>
    </ul>
  </div>
</section>

<!-- ══ FINAL CTA ═══════════════════════════════════════════════════════════ -->
<%- include('../partials/cta', { heading: 'Ready to build an outbound operation you actually own?', text: 'Tell us how you get customers today and what you have already tried. We will scope the setup — what to build, what you already have, and what you should own by the end. If it is not a fit, we will tell you.' }) %>
