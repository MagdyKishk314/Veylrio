<!-- ══ HEADER ══════════════════════════════════════════════════════════════ -->
<section class="relative overflow-hidden bg-ink-800 text-cream">
  <div class="pointer-events-none absolute inset-0 pattern-tile opacity-[0.06]" aria-hidden="true"></div>
  <div class="pointer-events-none absolute -right-24 -top-20 h-72 w-72 rounded-full bg-clay-600/15 blur-3xl" aria-hidden="true"></div>
  <div class="container relative">
    <div class="max-w-3xl py-20 md:py-28">
      <p class="eyebrow eyebrow--on-dark">Solutions</p>
      <h1 class="mt-5 text-display text-cream">Connected operational systems for outbound teams.</h1>
      <p class="lead lead--on-dark mt-6 max-w-2xl">
        Five systems that work on their own and reinforce each other. We set them up, clean up what
        is already there, and hand over infrastructure your team can run and grow into.
      </p>
      <div class="mt-9 flex flex-col gap-3 sm:flex-row">
        <a href="<%= site.cta.primary.href %>" class="btn-on-dark"><%= site.cta.primary.label %><%- icon('arrow-right', 'arrow h-4 w-4') %></a>
        <a href="#outbound-infrastructure" class="btn-outline-on-dark">See the systems</a>
      </div>
    </div>
  </div>
</section>

<!-- ══ POSITIONING NOTE ════════════════════════════════════════════════════ -->
<section class="bg-paper-100 py-8">
  <div class="container">
    <div class="mx-auto flex max-w-4xl flex-col gap-4 rounded-2xl border border-ink-700/10 bg-white p-6 shadow-card sm:flex-row sm:items-center">
      <span class="icon-badge icon-badge--clay shrink-0"><%- icon('users', 'h-6 w-6') %></span>
      <p class="text-ink-600">
        <strong class="font-semibold text-ink-700">We do not provide callers by default.</strong>
        Veylrio builds the infrastructure, systems, tracking, QA, dialer setup, dashboards, workflows
        and advisory that make outbound teams work properly. Caller hiring support is available as an
        optional add-on.
      </p>
    </div>
  </div>
</section>

<!-- ══ SOLUTION GROUPS ═════════════════════════════════════════════════════ -->
<% site.solutionGroups.forEach(function (group, idx) {
     const shaded = idx % 2 === 1;
%>
  <section id="<%= group.id %>" class="section-y <%= shaded ? 'bg-paper-100' : 'bg-paper' %>">
    <div class="container">
      <div class="grid gap-10 lg:grid-cols-12">
        <!-- Group header -->
        <div class="lg:col-span-4">
          <div class="lg:sticky lg:top-28">
            <div class="flex items-center gap-4">
              <span class="icon-badge icon-badge--clay"><%- icon(group.icon, 'h-6 w-6') %></span>
              <span class="font-display font-semibold text-2xl text-ink-200"><%= group.number %></span>
            </div>
            <h2 class="mt-5 text-2xl font-semibold text-ink-700 md:text-3xl"><%= group.title %></h2>
            <p class="mt-4 text-ink-500"><%= group.description %></p>
            <a href="<%= site.cta.primary.href %>" class="mt-6 inline-flex items-center gap-2 font-semibold text-clay-700 hover:text-clay-800">
              Start with <%= group.title %>
              <%- icon('arrow-right', 'arrow h-4 w-4') %>
            </a>
          </div>
        </div>

        <!-- Group items -->
        <div class="lg:col-span-8">
          <ul class="grid gap-4 sm:grid-cols-2">
            <% group.items.forEach(function (item) { %>
              <li class="card-pad h-full">
                <div class="flex items-start gap-3">
                  <span class="mt-0.5 flex h-7 w-7 shrink-0 items-center justify-center rounded-full bg-ink-700/[0.06] text-ink-700">
                    <%- icon('check', 'h-4 w-4') %>
                  </span>
                  <div>
                    <h3 class="text-base font-semibold text-ink-700"><%= item.title %></h3>
                    <p class="mt-1.5 text-sm leading-relaxed text-ink-500"><%= item.text %></p>
                  </div>
                </div>
              </li>
            <% }); %>
          </ul>
        </div>
      </div>
    </div>
  </section>
<% }); %>

<!-- ══ HOW IT FITS TOGETHER ════════════════════════════════════════════════ -->
<section class="section-y bg-paper">
  <div class="container">
    <div class="mx-auto max-w-3xl text-center">
      <p class="eyebrow">How it fits together</p>
      <h2 class="mt-4 text-display-sm">One operation, built in the order that pays off fastest.</h2>
      <p class="lead mt-5">
        You do not need everything at once. We map what is costing you the most, fix that first, and
        layer in the rest as your operation steadies — always in tools you own.
      </p>
    </div>
    <ol class="mt-14 grid gap-5 sm:grid-cols-2 lg:grid-cols-4">
      <% site.process.forEach(function (step) { %>
        <li class="card-pad h-full">
          <span class="font-display font-semibold text-3xl text-clay-600/30"><%= step.number %></span>
          <h3 class="mt-3 text-lg font-semibold text-ink-700"><%= step.title %></h3>
          <p class="mt-2 text-sm leading-relaxed text-ink-500"><%= step.text %></p>
        </li>
      <% }); %>
    </ol>
  </div>
</section>

<!-- ══ FINAL CTA ═══════════════════════════════════════════════════════════ -->
<%- include('../partials/cta', { heading: 'Tell us which system to start with.', text: 'Share how your outbound runs today and where it breaks. We will recommend the system that takes the most weight off first — and a practical way to build it.' }) %>
