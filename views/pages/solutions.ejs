<!-- ══ HEADER ══════════════════════════════════════════════════════════════ -->
<section class="relative overflow-hidden">
  <div class="pointer-events-none absolute -right-40 -top-32 -z-10 h-[30rem] w-[30rem] rounded-full bg-clay-500/10 blur-[120px]" aria-hidden="true"></div>
  <div class="container relative">
    <div class="max-w-3xl py-20 md:py-28">
      <p class="eyebrow">Solutions</p>
      <h1 class="mt-5 text-display">Three ways to build and own your outbound.</h1>
      <p class="lead mt-6 max-w-2xl">
        Start from zero, get the caller and the system together, or bring an operation back under your
        control. Either way, you keep the dialer, CRM, data, and reporting.
      </p>
      <div class="mt-9 flex flex-col gap-3 sm:flex-row">
        <a href="<%= site.cta.primary.href %>" class="btn-primary"><%= site.cta.primary.label %><%- icon('arrow-right', 'arrow h-4 w-4') %></a>
        <a href="/#own-vs-rent" class="btn-secondary">Compare Own vs Rent</a>
      </div>
    </div>
  </div>
</section>

<!-- ══ POSITIONING NOTE ════════════════════════════════════════════════════ -->
<section class="pb-4">
  <div class="container">
    <div class="mx-auto flex max-w-4xl flex-col gap-4 rounded-2xl border border-cream/10 bg-ink-800 p-6 sm:flex-row sm:items-center">
      <span class="icon-badge icon-badge--clay shrink-0"><%- icon('users', 'h-6 w-6') %></span>
      <p class="text-paper-200/80">
        <strong class="font-semibold text-cream">We are not a lead-gen agency or a staffing agency.</strong>
        If you need a caller we help source one; if you have a caller we build the system around them.
        No public pricing — we scope around what you should own by the end.
      </p>
    </div>
  </div>
</section>

<!-- ══ THREE PRIMARY PATHS ═════════════════════════════════════════════════ -->
<section class="section-y">
  <div class="container">
    <div class="grid gap-5 lg:grid-cols-3">
      <% site.offers.forEach(function (offer, i) { %>
        <article id="<%= offer.id %>" class="card-pad card-hover flex h-full scroll-mt-24 flex-col">
          <div class="flex items-center justify-between">
            <span class="icon-badge icon-badge--clay"><%- icon(offer.icon, 'h-6 w-6') %></span>
            <span class="font-display text-2xl font-semibold text-cream/15"><%= String(i + 1).padStart(2, '0') %></span>
          </div>
          <h2 class="mt-5 text-xl font-semibold text-cream"><%= offer.title %></h2>
          <p class="mt-2 font-serif text-base italic text-clay-400"><%= offer.positioning %></p>
          <p class="mt-4 text-sm text-paper-200/65"><%= offer.who %></p>

          <div class="my-6 rule"></div>

          <ul class="flex-1 space-y-3">
            <% offer.includes.forEach(function (item) { %>
              <li class="flex items-start gap-3">
                <span class="mt-0.5 text-clay-400"><%- icon('check', 'h-4 w-4') %></span>
                <span class="text-sm text-paper-200/85"><%= item %></span>
              </li>
            <% }); %>
          </ul>

          <a href="<%= site.cta.primary.href %>" class="mt-7 inline-flex items-center gap-2 text-sm font-semibold text-clay-400 hover:text-clay-300">
            Start with this path
            <%- icon('arrow-right', 'arrow h-4 w-4') %>
          </a>
        </article>
      <% }); %>
    </div>
  </div>
</section>

<!-- ══ VENDOR & OUTBOUND ADVISORY (secondary lane) ═════════════════════════ -->
<section class="section-y">
  <div class="container">
    <div class="mx-auto max-w-4xl text-center">
      <p class="eyebrow">A lighter path</p>
      <h2 class="mt-4 text-2xl font-semibold text-cream md:text-3xl">Not ready to build? Start with advisory.</h2>
      <p class="mt-4 text-paper-200/70">
        If building your own setup is not the right move yet, we can still help you avoid bad
        outbound decisions.
      </p>
    </div>

    <div id="<%= site.advisoryPath.id %>" class="mx-auto mt-10 max-w-4xl scroll-mt-24 overflow-hidden rounded-3xl border border-clay-400/25 bg-ink-800 p-8 md:p-10">
      <div class="grid gap-8 lg:grid-cols-12">
        <div class="lg:col-span-5">
          <span class="icon-badge icon-badge--clay"><%- icon(site.advisoryPath.icon, 'h-6 w-6') %></span>
          <h3 class="mt-5 text-xl font-semibold text-cream"><%= site.advisoryPath.title %></h3>
          <p class="mt-2 font-serif text-base italic text-clay-400"><%= site.advisoryPath.positioning %></p>
          <p class="mt-4 text-sm text-paper-200/65"><%= site.advisoryPath.who %></p>
          <a href="<%= site.cta.advisory.href %>" class="mt-6 inline-flex items-center gap-2 text-sm font-semibold text-clay-400 hover:text-clay-300">
            <%= site.cta.advisory.label %>
            <%- icon('arrow-right', 'arrow h-4 w-4') %>
          </a>
        </div>
        <div class="lg:col-span-7">
          <ul class="grid gap-3 sm:grid-cols-2">
            <% site.advisoryPath.includes.forEach(function (item) { %>
              <li class="flex items-start gap-3 rounded-xl border border-cream/10 bg-cream/[0.03] px-4 py-3">
                <span class="mt-0.5 text-clay-400"><%- icon('check', 'h-4 w-4') %></span>
                <span class="text-sm text-paper-200/85"><%= item %></span>
              </li>
            <% }); %>
          </ul>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ══ OPTIONAL SUPPORT (subordinate) ══════════════════════════════════════ -->
<section class="section-y band">
  <div class="container">
    <div class="mx-auto max-w-3xl text-center">
      <p class="eyebrow">Optional support</p>
      <h2 class="mt-4 text-2xl font-semibold text-cream md:text-3xl">You own the operation. We stay available when you want help.</h2>
      <p class="mt-4 text-paper-200/70">None of this is required. Use it only when it is useful.</p>
    </div>
    <ul class="mx-auto mt-10 grid max-w-4xl gap-3 sm:grid-cols-2">
      <% site.optionalSupport.forEach(function (s) { %>
        <li class="flex items-start gap-3 rounded-xl border border-cream/10 bg-ink-800 px-5 py-4">
          <span class="mt-0.5 flex h-7 w-7 shrink-0 items-center justify-center rounded-lg bg-cream/[0.06] text-clay-400">
            <%- icon('check', 'h-4 w-4') %>
          </span>
          <div>
            <p class="text-sm font-semibold text-cream"><%= s.title %></p>
            <p class="mt-1 text-sm text-paper-200/60"><%= s.text %></p>
          </div>
        </li>
      <% }); %>
    </ul>
  </div>
</section>

<!-- ══ HOW IT WORKS ════════════════════════════════════════════════════════ -->
<section class="section-y">
  <div class="container">
    <div class="mx-auto max-w-3xl text-center">
      <p class="eyebrow">How it works</p>
      <h2 class="mt-4 text-display-sm">Simple to start. Built to be owned.</h2>
    </div>
    <ol class="mt-14 grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
      <% site.process.forEach(function (step) { %>
        <li class="card-pad h-full">
          <span class="font-display text-3xl font-semibold text-clay-400/35"><%= step.number %></span>
          <h3 class="mt-3 text-lg font-semibold text-cream"><%= step.title %></h3>
          <p class="mt-2 text-sm leading-relaxed text-paper-200/65"><%= step.text %></p>
        </li>
      <% }); %>
    </ol>
  </div>
</section>

<!-- ══ FINAL CTA ═══════════════════════════════════════════════════════════ -->
<%- include('../partials/cta', { heading: 'Not sure which path fits?', text: 'Tell us where you are now and what you want to build or fix. We will recommend the simplest path and what it should include.' }) %>
