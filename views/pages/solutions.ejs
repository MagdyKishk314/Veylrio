<!-- ══ HEADER ══════════════════════════════════════════════════════════════ -->
<section class="relative overflow-hidden bg-ink-800 text-cream">
  <div class="pointer-events-none absolute inset-0 pattern-tile opacity-[0.06]" aria-hidden="true"></div>
  <div class="pointer-events-none absolute -right-24 -top-20 h-72 w-72 rounded-full bg-clay-600/15 blur-3xl" aria-hidden="true"></div>
  <div class="container relative">
    <div class="max-w-3xl py-20 md:py-28">
      <p class="eyebrow eyebrow--on-dark">Solutions</p>
      <h1 class="mt-5 text-display text-cream">Ways to build and own your outbound.</h1>
      <p class="lead lead--on-dark mt-6 max-w-2xl">
        Whether you are starting from scratch, leaving a vendor, or hiring your first caller, we
        build the setup you keep — and stay available for support only when it is useful.
      </p>
      <div class="mt-9 flex flex-col gap-3 sm:flex-row">
        <a href="<%= site.cta.primary.href %>" class="btn-on-dark"><%= site.cta.primary.label %><%- icon('arrow-right', 'arrow h-4 w-4') %></a>
        <a href="#<%= site.offers[0].id %>" class="btn-outline-on-dark">See the offers</a>
      </div>
    </div>
  </div>
</section>

<!-- ══ POSITIONING NOTE ════════════════════════════════════════════════════ -->
<section class="bg-paper-100 py-8">
  <div class="container">
    <div class="mx-auto flex max-w-4xl flex-col gap-4 rounded-2xl border border-ink-700/10 bg-white p-6 shadow-card sm:flex-row sm:items-center">
      <span class="icon-badge icon-badge--clay shrink-0"><%- icon('users', 'h-6 w-6') %></span>
      <p class="text-ink-600">
        <strong class="font-semibold text-ink-700">We are not a lead-gen agency or a staffing agency.</strong>
        If you need a caller we help source one; if you have a caller we build the system around them.
        Either way, the dialer, CRM, data process, and reporting belong to you. No public pricing —
        we scope around what you need to own by the end.
      </p>
    </div>
  </div>
</section>

<!-- ══ OFFERS ══════════════════════════════════════════════════════════════ -->
<% site.offers.forEach(function (offer, idx) {
     const shaded = idx % 2 === 1;
%>
  <section id="<%= offer.id %>" class="section-y <%= shaded ? 'bg-paper-100' : 'bg-paper' %>">
    <div class="container">
      <div class="grid gap-10 lg:grid-cols-12">
        <!-- Offer header -->
        <div class="lg:col-span-5">
          <div class="lg:sticky lg:top-28">
            <div class="flex items-center gap-4">
              <span class="icon-badge icon-badge--clay"><%- icon(offer.icon, 'h-6 w-6') %></span>
              <span class="font-display text-2xl font-semibold text-ink-200"><%= String(idx + 1).padStart(2, '0') %></span>
            </div>
            <h2 class="mt-5 text-2xl font-semibold text-ink-700 md:text-3xl"><%= offer.title %></h2>
            <p class="mt-3 font-serif text-lg italic text-clay-700"><%= offer.positioning %></p>
            <p class="mt-4 text-ink-500"><span class="font-semibold text-ink-700">Best for:</span> <%= offer.who %></p>
            <a href="<%= site.cta.primary.href %>" class="mt-6 inline-flex items-center gap-2 font-semibold text-clay-700 hover:text-clay-800">
              Start with <%= offer.title %>
              <%- icon('arrow-right', 'arrow h-4 w-4') %>
            </a>
          </div>
        </div>

        <!-- What's included -->
        <div class="lg:col-span-7">
          <p class="text-xs font-semibold uppercase tracking-eyebrow text-ink-400">What it includes</p>
          <ul class="mt-4 grid gap-4 sm:grid-cols-2">
            <% offer.includes.forEach(function (item) { %>
              <li class="card-pad flex items-start gap-3">
                <span class="mt-0.5 flex h-7 w-7 shrink-0 items-center justify-center rounded-full bg-ink-700/[0.06] text-ink-700">
                  <%- icon('check', 'h-4 w-4') %>
                </span>
                <span class="text-sm font-medium text-ink-700"><%= item %></span>
              </li>
            <% }); %>
          </ul>
        </div>
      </div>
    </div>
  </section>
<% }); %>

<!-- ══ HOW IT WORKS ════════════════════════════════════════════════════════ -->
<section class="relative overflow-hidden bg-ink-700 text-cream">
  <div class="pointer-events-none absolute inset-0 pattern-tile opacity-[0.05] mask-fade-y" aria-hidden="true"></div>
  <div class="container relative section-y">
    <div class="mx-auto max-w-3xl text-center">
      <p class="eyebrow eyebrow--on-dark justify-center">How it works</p>
      <h2 class="mt-4 text-display-sm text-cream">Built in the order that makes sense for you.</h2>
      <p class="lead lead--on-dark mx-auto mt-5 max-w-2xl">
        You do not need everything at once. We start with the simplest setup that fits, then layer in
        the rest — always in tools you own.
      </p>
    </div>
    <ol class="mt-14 grid gap-px overflow-hidden rounded-2xl border border-cream/10 bg-cream/10 sm:grid-cols-2 lg:grid-cols-3">
      <% site.process.forEach(function (step) { %>
        <li class="bg-ink-700 p-6 md:p-7">
          <span class="font-display text-3xl font-semibold text-clay-400/40"><%= step.number %></span>
          <h3 class="mt-3 text-lg font-semibold text-cream"><%= step.title %></h3>
          <p class="mt-2 text-sm leading-relaxed text-paper-200/80"><%= step.text %></p>
        </li>
      <% }); %>
    </ol>
  </div>
</section>

<!-- ══ FINAL CTA ═══════════════════════════════════════════════════════════ -->
<%- include('../partials/cta', { heading: 'Tell us where you are, and what you want to own.', text: 'Starting fresh, leaving a vendor, or adding a caller — we will recommend the simplest way to build the setup you keep, and what it should include.' }) %>
