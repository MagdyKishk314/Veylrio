# ──────────────────────────────────────────────────────────────────────────
# Veylrio website — environment configuration
# Copy this file to ".env" and fill in real values. NEVER commit ".env".
# ──────────────────────────────────────────────────────────────────────────

# Runtime
NODE_ENV=development
PORT=3000

# Canonical public origin (no trailing slash). Used for canonical URLs,
# Open Graph tags, sitemap.xml and robots.txt.
SITE_URL=https://veylrio.com

# Public-facing contact details (rendered in the UI).
CONTACT_EMAIL=contact@veylrio.com

# Secret used to sign cookies. Generate with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
COOKIE_SECRET=replace-with-a-long-random-string

# Set to 1 when the app runs behind a reverse proxy / load balancer
# (Heroku, Render, Nginx, Cloudflare, etc.) so rate-limiting and secure
# cookies see the real client IP and protocol. Leave 0 for local dev.
TRUST_PROXY=0

# ──────────────────────────────────────────────────────────────────────────
# Project inquiry handling
# ──────────────────────────────────────────────────────────────────────────
# Where new "Start a Project" inquiries should eventually be delivered.
INQUIRY_NOTIFY_TO=contact@veylrio.com

# Email provider for inquiry notifications. Leave as "log" until you wire up
# a real provider. Supported (future): log | smtp | sendgrid | resend
MAIL_PROVIDER=log

# --- SMTP (only used when MAIL_PROVIDER=smtp) ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Veylrio <no-reply@veylrio.com>"

# --- SendGrid (only used when MAIL_PROVIDER=sendgrid) ---
SENDGRID_API_KEY=

# --- Resend (only used when MAIL_PROVIDER=resend) ---
RESEND_API_KEY=
