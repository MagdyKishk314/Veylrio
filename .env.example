# ──────────────────────────────────────────────────────────────────────────
# Veylrio website — environment configuration
# Copy this file to ".env" and fill in real values. NEVER commit ".env".
# ──────────────────────────────────────────────────────────────────────────

# Runtime
NODE_ENV=development
PORT=3000

# Canonical public origin (no trailing slash). Used for canonical URLs,
# Open Graph tags, sitemap.xml and robots.txt.
SITE_URL=https://veylrio.com

# Public-facing contact details (rendered in the UI).
CONTACT_EMAIL=contact@veylrio.com

# ──────────────────────────────────────────────────────────────────────────
# Inquiry notifications — Gmail SMTP
# ──────────────────────────────────────────────────────────────────────────
# Leave GMAIL_USER / GMAIL_APP_PASSWORD blank to just record submissions
# locally (logs/submissions.log) without sending email — handy in development.
#
# To enable email: in your Google account turn on 2-Step Verification, then
# create an App Password (Google Account → Security → App passwords) and paste
# the 16-character value below. Use the App Password, NOT your Gmail password.
GMAIL_USER=
GMAIL_APP_PASSWORD=

# Where new inquiries are delivered (defaults to CONTACT_EMAIL if blank).
INQUIRY_NOTIFY_TO=contact@veylrio.com

# Display name on the notification email.
MAIL_FROM_NAME=Veylrio Website
